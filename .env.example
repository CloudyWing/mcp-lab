COMPOSE_PROJECT_NAME=mcp-lab
TZ=Asia/Taipei

# ── Base Images ───────────────────────────────
PYTHON_TAG=3.12-slim
DOTNET_TAG=10.0

# ── MCP Ports ─────────────────────────────────
# 資料庫服務 (9800-9819)
MCP_SQL_SERVER_PORT=9800
MCP_ORACLE_PORT=9801
MCP_ELASTICSEARCH_PORT=9802
MCP_REDIS_PORT=9803

# 訊息服務 (9820-9839)
MCP_MOSQUITTO_PORT=9820
MCP_RABBITMQ_PORT=9821

# 文件服務 (9840-9859)
MCP_READER_PORT=9840

# ── SQL Server Connections ────────────────────
# MSSQL_CONN_{ALIAS}_* — ALIAS 為大寫英數（建議用英文代號）
MSSQL_CONN_PROD_NAME=
MSSQL_CONN_PROD_HOST=
MSSQL_CONN_PROD_PORT=1433
MSSQL_CONN_PROD_USER=
MSSQL_CONN_PROD_PASSWORD=
MSSQL_CONN_PROD_DATABASE=

# 第二個 SQL Server（選用）
# MSSQL_CONN_STAGE_NAME=
# MSSQL_CONN_STAGE_HOST=
# MSSQL_CONN_STAGE_PORT=1433
# MSSQL_CONN_STAGE_USER=
# MSSQL_CONN_STAGE_PASSWORD=
# MSSQL_CONN_STAGE_DATABASE=

# ── Oracle Connections ────────────────────────
# ORACLE_CONN_{ALIAS}_*
ORACLE_CONN_PROD_NAME=
ORACLE_CONN_PROD_HOST=
ORACLE_CONN_PROD_PORT=1521
ORACLE_CONN_PROD_SERVICE=
ORACLE_CONN_PROD_USER=
ORACLE_CONN_PROD_PASSWORD=

# ── Elasticsearch Connections ─────────────────
# ES_CONN_{ALIAS}_*  URL 格式：http://host:9200 或 https://host:9200
ES_CONN_PROD_NAME=
ES_CONN_PROD_URL=
ES_CONN_PROD_USER=
ES_CONN_PROD_PASSWORD=
ES_CONN_PROD_SSL_SKIP_VERIFY=

# ── Redis Connections ─────────────────────────
# REDIS_CONN_{ALIAS}_*
REDIS_CONN_PROD_NAME=
REDIS_CONN_PROD_HOST=
REDIS_CONN_PROD_PORT=6379
REDIS_CONN_PROD_DATABASE=
REDIS_CONN_PROD_PASSWORD=

# ── MQTT Connections ──────────────────────────
# MQTT_CONN_{ALIAS}_*
MQTT_CONN_PROD_NAME=
MQTT_CONN_PROD_HOST=
MQTT_CONN_PROD_PORT=1883
MQTT_CONN_PROD_USER=
MQTT_CONN_PROD_PASSWORD=

# ── RabbitMQ Connections ──────────────────────
# RABBITMQ_CONN_{ALIAS}_*
RABBITMQ_CONN_PROD_NAME=
RABBITMQ_CONN_PROD_HOST=
RABBITMQ_CONN_PROD_MGMTPORT=15672
RABBITMQ_CONN_PROD_USER=
RABBITMQ_CONN_PROD_PASSWORD=

# ── Documents Settings ────────────────────────
DOCUMENT_HOST_MOUNT_ROOT=
DOCUMENT_MAX_IMAGES=20
DOCUMENT_MAX_TEXT_MB=10
